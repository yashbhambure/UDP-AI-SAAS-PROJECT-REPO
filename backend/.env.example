# ──────────────────────────────────────────────
# Tick-It AI — Environment Variables Template
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# MongoDB
MONGO_URI=your_mongo_uri_here

# LLM (text generation - extraction, insights, RAG)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Vector DB (ChromaDB — run: pip install chromadb && chroma run --host localhost --port 8000)
VECTOR_DB_URL=http://localhost:8000
VECTOR_DB_TYPE=chroma

# Twilio for SMS Notification
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Resend for Email Notification
RESEND_API_KEY=your_resend_api_key_here

# Reminders (days before deadline to fire; comma-separated)
REMINDER_DAYS_BEFORE=7,2,0
# Cron expression for reminder worker (every 5 minutes)
REMINDER_CRON=*/5 * * * *

# File Upload
MAX_FILE_SIZE_MB=25
